  "description": "巴西化妆品功效宣称限制 - 禁止药品功效用语",
  "rules": [
    {
      "ruleId": "BR-CLAIM-001",
      "category": "claim",
      "target": "治疗",
      "aliases": ["Tratar", "治疗", "tratamiento", "curar", "治愈", "cura", "cura completamente", "cura definitiva"],
      "severity": "critical",
      "condition": "禁止使用治疗疾病相关宣称",
      "message": "化妆品不得宣称具有治疗疾病的效果，如'治疗痤疮'、'治疗湿疹'等",
      "sourceUrl": "https://www.gov.br/anvisa/pt-br/assuntos/cosmeticos/legislacao-vigente-1"
    },
    {
      "ruleId": "BR-CLAIM-013",
      "category": "claim",
      "target": "永久/彻底根治",
