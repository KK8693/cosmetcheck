{
  "source": "ANVISA",
  "documentId": "RDC 169/2024",
  "version": "2024-06",
  "description": "巴西化妆品标签法规 - 强制标识要求",
  "rules": [
    {
      "ruleId": "BR-LABEL-001",
      "category": "label",
      "target": "Product name in Portuguese",
      "aliases": [
        "Nome em português",
        "葡萄牙语产品名",
        "名称葡语化"
      ],
      "severity": "critical",
      "condition": "产品名称必须翻译为葡萄牙语",
      "message": "Product name must be in Portuguese per RDC 169/2024.",
      "sourceUrl": "https://www.gov.br/anvisa/pt-br/assuntos/cosmeticos/legislacao-vigente-1"
    },
    {
      "ruleId": "BR-LABEL-002",
      "category": "label",
      "target": "INCI name",
      "aliases": [
        "Nome INCI",
        "INCI命名",
        "国际成分命名"
      ],
      "severity": "critical",
      "condition": "成分表必须使用INCI国际命名",
      "message": "Ingredients must be listed using INCI (International Nomenclature of Cosmetic Ingredients) standard.",
      "sourceUrl": "https://www.gov.br/anvisa/pt-br/assuntos/cosmeticos/legislacao-vigente-1"
    },
    {
      "ruleId": "BR-LABEL-003",
      "category": "label",
      "target": "Manufacturer info",
      "aliases": [
        "Dados do fabricante",
        "制造商信息"
      ],
      "severity": "critical",
      "condition": "必须标注制造商或进口商信息",
      "message": "Manufacturer or importer name, address, and CNPJ must be displayed.",
      "sourceUrl": "https://www.gov.br/anvisa/pt-br/assuntos/cosmeticos/legislacao-vigente-1"
    },
    {
      "ruleId": "BR-LABEL-004",
      "category": "label",
      "target": "Country of origin",
      "aliases": [
        "País de origem",
        "原产国"
      ],
      "severity": "critical",
      "condition": "必须标注原产国",
      "message": "Country of origin must be displayed for imported products.",
      "sourceUrl": "https://www.gov.br/anvisa/pt-br/assuntos/cosmeticos/legislacao-vigente-1"
    },
    {
      "ruleId": "BR-LABEL-005",
      "category": "label",
      "target": "Net content",
      "aliases": [
        "Conteúdo líquido",
        "净含量"
      ],
      "severity": "critical",
      "condition": "必须标注净含量",
      "message": "Net content must be displayed using metric units (g, mL).",
      "sourceUrl": "https://www.gov.br/anvisa/pt-br/assuntos/cosmeticos/legislacao-vigente-1"
    },
    {
      "ruleId": "BR-LABEL-006",
      "category": "label",
      "target": "Batch number",
      "aliases": [
        "Número do lote",
        "批号"
      ],
      "severity": "warning",
      "condition": "必须标注生产批号",
      "message": "Batch number must be displayed for product traceability.",
      "sourceUrl": "https://www.gov.br/anvisa/pt-br/assuntos/cosmeticos/legislacao-vigente-1"
    },
    {
      "ruleId": "BR-LABEL-007",
      "category": "label",
      "target": "Expiration date",
      "aliases": [
        "Data de validade",
        "有效期"
      ],
      "severity": "critical",
      "condition": "必须标注有效期",
      "message": "Expiration date (or Period After Opening - PAO) must be displayed.",
      "sourceUrl": "https://www.gov.br/anvisa/pt-br/assuntos/cosmeticos/legislacao-vigente-1"
    },
    {
      "ruleId": "BR-LABEL-008",
      "category": "label",
      "target": "Storage conditions",
      "aliases": [
        "Condições de armazenamento",
        "储存条件"
      ],
      "severity": "info",
      "condition": "建议标注",
      "message": "Storage conditions should be displayed (e.g., 'store away from light', 'store at room temperature').",
      "sourceUrl": "https://www.gov.br/anvisa/pt-br/assuntos/cosmeticos/legislacao-vigente-1"
    },
    {
      "ruleId": "BR-LABEL-009",
      "category": "label",
      "target": "Registration number",
      "aliases": [
        "Número de registro",
        "注册编号"
      ],
      "severity": "critical",
      "condition": "必须标注ANVISA注册编号",
      "message": "ANVISA registration number must be displayed (unless exempt).",
      "sourceUrl": "https://www.gov.br/anvisa/pt-br/assuntos/cosmeticos/legislacao-vigente-1"
    },
    {
      "ruleId": "BR-LABEL-010",
      "category": "label",
      "target": "Consumer service",
      "aliases": [
        "SAC",
        "Serviço de Atendimento ao Consumidor",
        "客服电话"
      ],
      "severity": "critical",
      "condition": "必须标注客服联系方式",
      "message": "Consumer service phone or email must be displayed.",
      "sourceUrl": "https://www.gov.br/anvisa/pt-br/assuntos/cosmeticos/legislacao-vigente-1"
    }
  ]
}