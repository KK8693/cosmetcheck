  "description": "巴西化妆品备案规则 - 进口产品预先备案要求",
  "rules": [
    {
      "ruleId": "BR-REG-001",
      "category": "registration",
      "target": "Import registration",
      "aliases": [
        "Registro de importação",
        "进口备案"
      ],
      "severity": "critical",
      "condition": "进口化妆品必须预先备案",
      "message": "Imported cosmetics must be pre-registered with ANVISA per RDC 48/2023.",
      "sourceUrl": "https://www.gov.br/anvisa/pt-br/assuntos/cosmeticos/legislacao-vigente-1"
    },
    {
      "ruleId": "BR-REG-002",
      "category": "registration",
      "target": "Registration number on package",
      "aliases": [
        "Número de registro na embalagem",
        "注册编号标注"
      ],
      "severity": "critical",
      "condition": "包装上必须标注ANVISA注册编号",
      "message": "ANVISA registration number must be clearly displayed on product packaging.",
      "sourceUrl": "https://www.gov.br/anvisa/pt-br/assuntos/cosmeticos/legislacao-vigente-1"
    },
    {
      "ruleId": "BR-REG-003",
      "category": "registration",
      "target": "Import license",
      "aliases": [
        "Licença de importação",
        "进口许可证"
      ],
      "severity": "critical",
      "condition": "必须持有有效的ANVISA进口许可",
      "message": "Importer must hold a valid ANVISA import license.",
      "sourceUrl": "https://www.gov.br/anvisa/pt-br/assuntos/cosmeticos/legislacao-vigente-1"
    },
    {
      "ruleId": "BR-REG-004",
      "category": "registration",
      "target": "Responsible technician",
      "aliases": [
        "Técnico responsável",
        "技术负责人"
      ],
      "severity": "critical",
      "condition": "必须有注册的巴西技术负责人",
      "message": "A technically responsible person (RT) registered with ANVISA is required.",
      "sourceUrl": "https://www.gov.br/anvisa/pt-br/assuntos/cosmeticos/legislacao-vigente-1"
    },
    {
      "ruleId": "BR-REG-005",
      "category": "registration",
      "target": "Product notification",
      "aliases": [
        "Notificação de produto",
        "产品通报"
      ],
      "severity": "warning",
      "condition": "部分产品只需通报，无需注册",
      "message": "Some low-risk products only require notification (Notificação), not full registration.",
      "sourceUrl": "https://www.gov.br/anvisa/pt-br/assuntos/cosmeticos/legislacao-vigente-1"
    },
    {
      "ruleId": "BR-REG-006",
      "category": "registration",
      "target": "Expiration monitoring",
      "aliases": [
        "Monitoramento de validade",
        "有效期监控"
      ],
      "severity": "info",
      "condition": "需监控产品有效期",
      "message": "Importer must monitor product expiration dates in the system.",
      "sourceUrl": "https://www.gov.br/anvisa/pt-br/assuntos/cosmeticos/legislacao-vigente-1"
    }
  ]
