{
  "source": "COFEPRIS",
  "documentId": "NOM-259-SSA1-2012 + LFPUB",
  "version": "2012-12",
  "description": "墨西哥化妆品功效宣称和广告法规",
  "rules": [
    {
      "ruleId": "MX-CLAIM-001",
      "category": "claim",
      "target": "医疗治疗/消炎抗菌",
      "aliases": [
        "curar",
        "治愈",
        "antibacteriano",
        "抗菌",
        "antimicrobiano",
        "抑菌",
        "antiinflamatorio",
        "消炎",
        "tratamiento médico",
        "医学治疗",
        "elimina acne",
        "去除痤疮",
        "cura heridas",
        "愈合伤口"
      ],
      "severity": "critical",
      "condition": "禁止化妆品宣称医疗治疗功效",
      "message": "Cosmetics cannot use medical terms like 'cure', 'anti-inflammatory', 'antibacterial'. Cannot claim to treat acne, wound healing or other drug efficacy.",
      "sourceUrl": "https://www.dof.gob.mx/nota_detalle.php?codigo=5325961&fecha=05/12/2012"
    },
    {
      "ruleId": "MX-CLAIM-002",
      "category": "claim",
      "target": "无添加/纯天然夸大",
      "aliases": [
        "100% natural",
        "100%天然",
        "sin químicos",
        "无化学成分",
        "sin conservantes",
        "无防腐剂",
        "orgánico",
        "有机",
        "comestible",
        "可食用",
        "food grade",
        "食品级"
      ],
      "severity": "warning",
      "condition": "禁止绝对化无添加/纯天然宣称",
      "message": "Avoid absolute terms like '100% natural', 'no chemicals'. Natural ingredient claims require scientific evidence.",
      "sourceUrl": "https://www.dof.gob.mx/nota_detalle.php?codigo=5325961&fecha=05/12/2012"
    },
    {
      "ruleId": "MX-CLAIM-003",
      "category": "claim",
      "target": "防晒绝对化宣称",
      "aliases": [
        "protección total contra UV",
        "全面防紫外线",
        "bloqueador total",
        "完全阻隔",
        "sin necesidad de reaplicar",
        "无需补涂",
        "protección 100%",
        "100%防晒"
      ],
      "severity": "critical",
      "condition": "禁止防晒绝对化和无需补涂宣称",
      "message": "Sunscreen products must display SPF value and UVA/UVB protection. Absolute claims like 'total protection' or 'no reapplication needed' are prohibited.",
      "sourceUrl": "https://www.dof.gob.mx/nota_detalle.php?codigo=5325961&fecha=05/12/2012"
    },
    {
      "ruleId": "MX-CLAIM-004",
      "category": "claim",
      "target": "无风险/绝不致敏",
      "aliases": [
        "sin ningún riesgo",
        "无任何风险",
        "no causa irritación",
        "绝不致敏",
        "hipoalergénico sin pruebas",
        "无测试低致敏",
        "seguro para todo el mundo",
        "人人安全可用"
      ],
      "severity": "warning",
      "condition": "禁止无依据的安全绝对化宣称",
      "message": "Cosmetics cannot claim drug-like effects without medicine registration.",
      "sourceUrl": "https://www.dof.gob.mx/nota_detalle.php?codigo=5325961&fecha=05/12/2012"
    },
    {
