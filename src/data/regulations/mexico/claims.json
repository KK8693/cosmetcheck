      "severity": "warning",
      "condition": "可使用但需科学依据",
      "message": "抗衰老宣称需有科学依据支持",
      "sourceUrl": "https://www.dof.gob.mx/nota_detalle.php?codigo=5325961&fecha=05/12/2012"
    },
    {
      "ruleId": "MX-CLAIM-003",
      "category": "claim",
      "target": "生发",
