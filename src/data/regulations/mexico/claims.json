      "condition": "需有测试支持",
      "message": "低致敏宣称需有临床测试支持，不可滥用",
      "sourceUrl": "https://www.dof.gob.mx/nota_detalle.php?codigo=5325961&fecha=05/12/2012"
    },
    {
      "ruleId": "MX-CLAIM-009",
      "category": "claim",
      "target": "no animal testing",
      "aliases": ["No tested on animals", "Sin pruebas en animales", "无动物测试"],
      "severity": "info",
      "condition": "需有证明文件",
      "message": "无动物测试宣称需有供应链证明文件",
      "sourceUrl": "https://www.dof.gob.mx/nota_detalle.php?codigo=5325961&fecha=05/12/2012"
    },
    {
      "ruleId": "MX-CLAIM-010",
"category": "claim",
      "target": "治愈",
      "aliases": ["Cure", "Curar", "治愈", "根治"],
      "severity": "critical",
      "condition": "禁止任何治愈宣称",
      "message": "化妆品不得使用任何'治愈'、'根治'等医疗用语",
      "sourceUrl": "https://www.dof.gob.mx/nota_detalle.php?codigo=5325961&fecha=05/12/2012"
    },
    {
      "ruleId": "MX-CLAIM-011",
      "category": "claim",
      "target": "去除脂肪团",
      "aliases": ["Cellulite removal", "Eliminación de celulitis", "去橘皮", "燃脂"],
      "severity": "critical",
      "condition": "禁止宣称去除脂肪团",
      "message": "化妆品不得宣称可以去除脂肪团（橘皮组织）",
      "sourceUrl": "https://www.dof.gob.mx/nota_detalle.php?codigo=5325961&fecha=05/12/2012"
    },
    {
      "ruleId": "MX-CLAIM-012",
      "category": "claim",
      "target": "丰胸",
      "aliases": ["Breast enlargement", "Aumento de senos", "隆胸", "丰乳"],
      "severity": "critical",
      "condition": "禁止任何丰乳宣称",
      "message": "化妆品不得宣称具有丰胸或改变胸部大小的效果",
      "sourceUrl": "https://www.dof.gob.mx/nota_detalle.php?codigo=5325961&fecha=05/12/2012"
    }
  ]
