      "condition": "需真实有效",
      "message": "如宣城 dermatologist tested，需有实际测试报告支持",
      "sourceUrl": "https://www.dof.gob.mx/nota_detalle.php?codigo=5325961&fecha=05/12/2012"
    },
    {
      "ruleId": "MX-CLAIM-008",
      "category": "claim",
      "target": "hypoallergenic",
      "aliases": ["Hippoalergénico", "低致敏", "无过敏"],
