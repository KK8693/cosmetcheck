      "message": "化妆品不得宣称具有生发效果",
      "sourceUrl": "https://www.dof.gob.mx/nota_detalle.php?codigo=5325961&fecha=05/12/2012"
    },
    {
      "ruleId": "MX-CLAIM-004",
      "category": "claim",
      "target": "减肥",
      "aliases": ["Weight loss", "Perder peso", "减肥", "瘦身"],
      "severity": "critical",
      "condition": "禁止宣称减肥效果",
      "message": "化妆品不得宣称具有减肥效果",
      "sourceUrl": "https://www.dof.gob.mx/nota_detalle.php?codigo=5325961&fecha=05/12/2012"
    },
    {
      "ruleId": "MX-CLAIM-005",
      "category": "claim",
      "target": "立即见效",
      "aliases": ["Immediate results", "Resultados inmediatos", "立即", "即刻"],
      "severity": "warning",
      "condition": "禁止绝对化宣称",
      "message": "禁止使用'立即'、'即刻'等绝对化用语",
      "sourceUrl": "https://www.dof.gob.mx/nota_detalle.php?codigo=5325961&fecha=05/12/2012"
    },
    {
      "ruleId": "MX-CLAIM-006",
      "category": "claim",
      "target": "FDA批准",
      "aliases": ["FDA approved", "Aprobado por FDA", "美国FDA认证"],
      "severity": "warning",
      "condition": "禁止误导性宣称",
      "message": "禁止误导消费者使用FDA批准标识，墨西哥产品需符合COFEPRIS规定",
      "sourceUrl": "https://www.dof.gob.mx/nota_detalle.php?codigo=5325961&fecha=05/12/2012"
    },
    {
      "ruleId": "MX-CLAIM-007",
      "category": "claim",
      "target": " dermatologist tested",
